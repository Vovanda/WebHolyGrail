# Offline dev fallback — используется если Infisical недоступен.
# Скопируй в .env.local (gitignored) и заполни.
# Только для local dev. В staging/prod секреты ОБЯЗАТЕЛЬНО через Infisical.

# Payload
PAYLOAD_SECRET=                              # openssl rand -hex 32
DATABASE_URI=file:./data/site.db
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
PAYLOAD_ALLOWED_ORIGINS=http://localhost:3000

# Client
NEXT_PUBLIC_CMS_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site identity
SITE_NAME=Holy Grail (local)

# S3 / MinIO local
S3_BUCKET=local-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/local-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
