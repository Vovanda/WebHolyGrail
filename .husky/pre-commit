#!/usr/bin/env sh
# Pre-commit: format staged files (lint-staged) + scan staged for secrets (gitleaks).
# Heavy typecheck / unit tests live in CI (see .github/workflows when set up).

pnpm exec lint-staged

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --config .gitleaks.toml
else
  echo "warn: gitleaks not installed, skipping staged-secret scan"
  echo "      install via: winget install Gitleaks.Gitleaks"
fi
