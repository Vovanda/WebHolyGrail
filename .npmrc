# pnpm 11 по дефолту при каждом `pnpm run` verify'ит node_modules vs pnpm-lock.yaml
# и при расхождении лезет в npm registry чтобы «дозаинсталлить». В runtime-контейнере
# CMS/client (Docker без outbound доступа к npmjs.org) это ловит ETIMEDOUT на 800+
# запросах и вешает старт CMS минут на 20. Отключаем — deps уже полностью installed
# на build-стадии, verify в runtime не нужен.
# https://pnpm.io/settings#verifydepsbeforerun
verify-deps-before-run=false
