# /opt/infisical/.env (chmod 600 на VPS — содержит критические секреты)
#
# Генерация значений (на VPS):
#   ENCRYPTION_KEY="$(openssl rand -hex 16)"        # 16 байт hex
#   AUTH_SECRET="$(openssl rand -base64 32)"        # 32 байт base64
#   POSTGRES_PASSWORD="$(openssl rand -hex 24)"     # любая длинная строка
#
# ENCRYPTION_KEY — критичен. Потеря = БД (со всеми секретами) нечитаема.
# Скопировать в backup (личное безопасное хранилище / encrypted Vault).

ENCRYPTION_KEY=
AUTH_SECRET=
POSTGRES_PASSWORD=

# Публичный URL instance. Должен совпадать с фактическим хостом, иначе
# magic links / OAuth / CORS поломаются.
SITE_URL=https://infisical.example.com
