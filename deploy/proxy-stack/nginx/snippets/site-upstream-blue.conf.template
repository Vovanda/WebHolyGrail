# Blue color upstream (active when /etc/nginx/snippets/<SITE_SLUG>-upstream-active.conf → this)
# <CMS_PORT> / <CLIENT_PORT> подставляются deploy.sh из PORT_BASE per-site.
upstream <SITE_SLUG>_cms { server 127.0.0.1:<CMS_PORT>; keepalive 32; }
upstream <SITE_SLUG>_client { server 127.0.0.1:<CLIENT_PORT>; keepalive 32; }
