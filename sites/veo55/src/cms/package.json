{
  "name": "veo55-cms",
  "version": "0.0.0",
  "private": true,
  "description": "Payload 3.x CMS для veo55. Отдельное Next-приложение (R3, см. memo HolyGrail/33).",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/index.ts",
    "seed:media": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-media.ts",
    "seed:home-achievement": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-home-achievement.ts",
    "seed:home-certified-notice": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-home-certified-notice.ts",
    "seed:puppies-page-certified-notice": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-puppies-page-certified-notice.ts",
    "seed:news-page": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-news-page.ts",
    "seed:fetch-pedigree": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-fetch-pedigree.ts",
    "seed:timeline-paws": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-timeline-paws.ts",
    "seed:home-litter-decomposition": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-home-litter-decomposition.ts",
    "seed:home-fix-litter": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-home-fix-litter.ts",
    "seed:rename-litter-page": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-rename-litter-page.ts",
    "seed:trim-litter-titles": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-trim-litter-titles.ts",
    "seed:rebuild-litter-page-slug": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/seed-rebuild-litter-page-slug.ts",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "migrate:down": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:down",
    "migrate:refresh": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:refresh",
    "migrate:fresh": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:fresh"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.40.0",
    "@payloadcms/next": "^3.40.0",
    "@payloadcms/richtext-lexical": "^3.40.0",
    "@payloadcms/storage-s3": "^3.85.1",
    "@payloadcms/translations": "^3.40.0",
    "@payloadcms/ui": "^3.40.0",
    "@veo55/contracts": "workspace:*",
    "cross-env": "^7.0.3",
    "next": "^15.0.3",
    "payload": "^3.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
