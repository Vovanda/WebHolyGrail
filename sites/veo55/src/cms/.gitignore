# Ignore contents but keep dirs (re-include .gitkeep).
# `dir/` форма игнорит сам каталог и .gitkeep оттуда не вытащить;
# `dir/*` — игнорит только содержимое, .gitkeep можно re-include'нуть.
data/*
media/*
!data/.gitkeep
!media/.gitkeep

