# Web Holy Grail — veo55 site
# СВОДНЫЙ шаблон переменных. Реальные значения — в Infisical workspace.
# Для локального запуска используй: infisical run --env=dev -- pnpm dev
#
# Эти ключи существуют в трёх окружениях: dev / staging / prod (project в Infisical).

# === Payload (cms) ===

# Секрет для подписи Payload JWT и других внутренних токенов.
# Min 32 ASCII символа. Генерация: `openssl rand -hex 32`.
PAYLOAD_SECRET=

# URL по которому Payload-приложение доступно (для CORS, превью, ссылок в письмах).
# dev: http://localhost:3001 | prod: https://admin.veo55.ru
PAYLOAD_PUBLIC_SERVER_URL=

# Путь к SQLite-файлу. В Docker — путь внутри контейнера, маппится на volume.
# dev: file:./data/veo55.db | docker: file:/data/veo55.db
DATABASE_URI=

# === Next (client) ===

# URL Payload API для серверных запросов из Next (server-side).
# dev: http://localhost:3001 | docker (внутри сети): http://cms:3001
NEXT_PUBLIC_CMS_URL=

# Публичный URL фронта (для абсолютных ссылок, OG-image, sitemap).
# dev: http://localhost:3000 | prod: https://veo55.ru
NEXT_PUBLIC_SITE_URL=

# === S3 / Media (когда подключим — Шаг 5) ===

# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=

# === SMTP (когда подключим — Шаг 6) ===

# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
