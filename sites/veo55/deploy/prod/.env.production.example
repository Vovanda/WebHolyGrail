# =========================================================================
# .env.production.example — шаблон prod-секретов для veo55
# =========================================================================
#
# КОПИРОВАТЬ:
#   cp .env.production.example .env.production
#   # отредактировать .env.production (он в .gitignore!)
#
# ИЛИ через Infisical (рекомендуется — секреты в облаке, не в файле):
#   infisical login                       # на dev-машине
#   infisical init                        # один раз
#   infisical secrets set <KEY>=<VALUE>   # для каждого секрета (или web UI)
#   infisical run --env=prod -- docker compose ...
#
# =========================================================================

# --- Payload CMS ---
# Сгенерируй случайный 64-char hex: openssl rand -hex 32
PAYLOAD_SECRET=

# Публичный URL CMS (используется для CORS, S3 signing, OG-images)
# На проде ставится корень с поддоменом или /admin суб-путём
PAYLOAD_PUBLIC_SERVER_URL=https://veo55.ru

# Публичный URL клиента (canonical, для SEO + cors)
NEXT_PUBLIC_SITE_URL=https://veo55.ru

# Bootstrap admin — создаётся seed только если коллекция users пуста.
# После первого запуска можно сменить через /admin/account.
ADMIN_INITIAL_EMAIL=
ADMIN_INITIAL_PASSWORD=

# --- S3-совместимое хранилище для Media ---
# VK Object Storage (https://mcs.mail.ru/docs/storage/s3) — он же CDN-источник
S3_BUCKET=veo55
S3_REGION=ru-msk
S3_ENDPOINT=https://hb.ru-msk.vkcloud-storage.ru
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- VK API ---
# Service token из сообщества (vk.com/dev → Создать ключ доступа).
# Не путать с user token (он короткоживущий).
VEO_VK_GROUP_ID=79230415
VEO_VK_APP_ID=
VEO_VK_SVC_TOKEN=
VEO_VK_API_VER=5.131

# --- Опционально: переопределить дефолты социал-фида ---
# VK_GROUP_SHORT_NAME=«Омская Дружина»   # короткое имя для UI-чипа
# VK_GROUP_URL=https://vk.com/veoomsk
# VK_GROUP_ME_URL=https://vk.me/veoomsk
# VK_GROUP_PHOTO=                          # URL аватарки сообщества

# --- Sync hide-tag ---
# VEO_SYNC_HIDE_TAG_REGEX=#экс?к?люз|#exclusive
