# === Holy Grail site — local dev .env.example ===
# Real secrets — through Infisical (`dev-setup.sh` → `.infisical.json`).
# This file lists what variables exist; values are placeholders.

# --- Payload CMS ---
PAYLOAD_SECRET=replace-with-64-hex-bytes
DATABASE_URI=file:./data/site.db
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
PAYLOAD_ALLOWED_ORIGINS=http://localhost:3000

# --- Next client ---
NEXT_PUBLIC_CMS_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Site identity ---
SITE_NAME=My Site
PUBLIC_URL=http://localhost:3001

# --- S3 / CDN (Media) ---
# Leave blank for local-disk storage (s3Storage plugin disabled if S3_BUCKET empty).
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Analytics (optional) ---
NEXT_PUBLIC_YM_ID=

# --- Social feed (optional) ---
VK_ACCESS_TOKEN=
VK_GROUP_URL=

NODE_ENV=development
